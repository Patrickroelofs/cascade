# Used by Payload CMS (the /admin beta) — no longer for auth, which now
# lives entirely in apps/app.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cascade
# Signs Payload's sessions/cookies for the /admin CMS (packages/tanstack-start beta). Any random 32+ char string.
PAYLOAD_SECRET=change-me-to-a-random-string-of-32-plus-chars
# Where "Go to app" / "Sign up" links point (apps/app owns login/register).
VITE_APP_URL=http://localhost:3001
